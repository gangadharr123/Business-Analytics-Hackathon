   "source": [
    "# Route Filtering for EBS Commute Use Cases\n",
    "\n",
    "Goal: reduce the nationwide DB feed to relevant stations/routes used by students commuting to campus, using **all monthly files** in the project data folder."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0f81e2b1",
   "metadata": {},
   "outputs": [
    {
     "ename": "",
     "evalue": "",
     "output_type": "error",
     "traceback": [
      "\u001b[1;31mFailed to start the Kernel. \n",
      "\u001b[1;31mUnable to start Kernel '.venv (3.14.3) (Python 3.14.3)' due to a timeout waiting for the ports to get used. \n",
      "\u001b[1;31mView Jupyter <a href='command:jupyter.viewOutput'>log</a> for further details."
     ]
    }
   ],
   "source": [
    "from pathlib import Path\n",
    "\n",
    "import pandas as pd\n",
    "import pyarrow.parquet as pq\n",
    "\n",
    "# Resolve project root from common notebook working directories.\n",
    "cwd = Path.cwd().resolve()\n",
    "candidate_roots = [cwd, *cwd.parents]\n",
    "project_root = next((p for p in candidate_roots if (p / \"README.md\").exists() and (p / \"src\").exists()), cwd)\n",
    "\n",
    "# Output path for the combined, filtered commute dataset.\n",
    "output_path = project_root / \"data\" / \"ebs_commute_data.csv\"\n",
    "output_path.parent.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Collect all monthly parquet files so analysis is based on the full timeline.\n",
    "parquet_files = sorted((project_root / \"data\" / \"raw\").glob(\"data-*.parquet\"))\n",
    "if not parquet_files:\n",
    "    parquet_files = sorted((project_root / \"data\").glob(\"data-*.parquet\"))\n",
    "\n",
    "if not parquet_files:\n",
    "    # Fallback: search recursively under data/ in case files are nested differently.\n",
    "    parquet_files = sorted((project_root / \"data\").rglob(\"data-*.parquet\"))\n",
    "\n",
    "if not parquet_files:\n",
    "    raise FileNotFoundError(\n",
    "        f\"No monthly parquet files found under {project_root / 'data'} (including subfolders).\"\n",
    "    )\n",
    "\n",
    "# Station list covers common starting points plus both campus destinations.\n",
    "target_stations = [\n",
    "    \"Frankfurt(Main)Hbf\",\n",
    "    \"Frankfurt-Höchst\",\n",
    "    \"Wiesbaden Hbf\",\n",
    "    \"Wiesbaden-Biebrich\",\n",
    "    \"Eltville\",\n",
    "    \"Oestrich-Winkel\",   # Campus A (Burg)\n",
    "    \"Hattenheim\",        # Campus B (Schloss)\n",
    "    \"Geisenheim\",\n",
    "    \"Rüdesheim(Rhein)\",\n",
    "]\n",
    "\n",
    "# Load only required columns in small batches and filter incrementally.\n",
    "columns_needed = [\n",
    "    \"time\",\n",
    "    \"station_name\",\n",
    "    \"delay_in_min\",\n",
    "    \"final_destination_station\",\n",
    "    \"train_type\",\n",
    "    \"train_name\",\n",
    "]\n",
    "\n",
    "filtered_chunks = []\n",
    "for file_path in parquet_files:\n",
    "    pf = pq.ParquetFile(file_path)\n",
    "    for batch in pf.iter_batches(columns=columns_needed, batch_size=50_000):\n",
    df_batch = batch.to_pandas()
    # Normalize station names by removing spaces
    df_batch["station_name"] = df_batch["station_name"].str.replace(" ", "", regex=False)

    # Filter for target stations AND trains containing \"RB10\" in their name.\n",
    keep = (\n",
        df_batch[\"station_name\"].isin(target_stations) & \n",
        df_batch[\"train_name\"].str.contains(\"RB10\", na=False, case=False)\n",
    )\n",
    "        if keep.any():\n",
    "            chunk = df_batch.loc[keep].copy()\n",
    "            # Normalize train_type to RB10 for consistency in the model\n",
    "            chunk[\"train_type\"] = \"RB10\"\n",
    "            filtered_chunks.append(chunk)\n",
    "\n",
    "if not filtered_chunks:\n",
    "    raise ValueError(\"Filtering produced zero rows. Check station names and input files.\")\n",
    "\n",
    "filtered_df = pd.concat(filtered_chunks, ignore_index=True)\n",
    "filtered_df.to_csv(output_path, index=False)\n",
    "\n",
    "print(f\"✅ Project root: {project_root}\")\n",
    "print(f\"✅ Processed {len(parquet_files)} file(s) and saved {len(filtered_df):,} rows to {output_path}\")\n",
    "filtered_df.head()"
   ]
  }
 ],
